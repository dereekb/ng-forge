{
  "name": "@ng-forge/dynamic-forms",
  "version": "0.8.0",
  "description": "Type-safe, signal-powered dynamic forms for Angular. Build complex forms from configuration with full TypeScript inference.",
  "type": "module",
  "license": "MIT",
  "author": "ng-forge",
  "homepage": "https://ng-forge.com/dynamic-forms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ng-forge/ng-forge.git",
    "directory": "packages/dynamic-forms"
  },
  "bugs": {
    "url": "https://github.com/ng-forge/ng-forge/issues"
  },
  "keywords": [
    "angular",
    "forms",
    "dynamic-forms",
    "reactive-forms",
    "signal-forms",
    "form-builder",
    "form-generator",
    "type-safe",
    "typescript",
    "angular-forms",
    "schema-forms",
    "json-forms",
    "config-driven"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@angular/common": "~21.2.0",
    "@angular/core": "~21.2.0",
    "@angular/forms": "~21.2.0",
    "@standard-schema/spec": "^1.0.0",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "ngxtension": ">=4.0.0",
    "tslib": "^2.3.0"
  },
  "module": "fesm2022/ng-forge-dynamic-forms.mjs",
  "typings": "types/ng-forge-dynamic-forms.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/ng-forge-dynamic-forms.d.ts",
      "default": "./fesm2022/ng-forge-dynamic-forms.mjs"
    },
    "./integration": {
      "types": "./types/ng-forge-dynamic-forms-integration.d.ts",
      "default": "./fesm2022/ng-forge-dynamic-forms-integration.mjs"
    },
    "./schema": {
      "types": "./types/ng-forge-dynamic-forms-schema.d.ts",
      "default": "./fesm2022/ng-forge-dynamic-forms-schema.mjs"
    }
  }
}